{
  "name": "learner-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/learner-e2e/src",
  "tags": ["scope:learner", "type:e2e"],
  "implicitDependencies": ["learner"],
  "targets": {
    "e2e": {
      "executor": "@nx/playwright:playwright",
      "outputs": ["{workspaceRoot}/dist/.playwright/apps/learner-e2e"],
      "options": {
        "config": "apps/learner-e2e/playwright.config.ts",
        "skipInstall": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
