{
  "$schema": "../../node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": ["/favicon.ico", "/index.html", "/manifest.webmanifest", "/*.css", "/*.js"]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/assets/**", "/*.(svg|png|jpg|jpeg|woff2)"]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-catalog",
      "urls": ["/api/catalog/**", "/api/courses/**"],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 100,
        "maxAge": "1d",
        "timeout": "5s"
      }
    },
    {
      "name": "api-dynamic",
      "urls": ["/api/**", "/**/*cloudfunctions.net/**", "/**/run.app/**"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 100,
        "maxAge": "1h",
        "timeout": "5s"
      }
    },
    {
      "name": "content-media",
      "urls": [
        "/**/*.mp4",
        "/**/*.webm",
        "/**/*.png",
        "/**/*.jpg",
        "/**/*.jpeg",
        "/**/*.gif",
        "/**/*.svg",
        "/**/*.woff2",
        "/**/*.woff",
        "/**/*.ttf"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 50,
        "maxAge": "7d",
        "timeout": "10s"
      }
    }
  ]
}
