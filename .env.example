# Soteria FORGE — example environment. Copy to .env (per app) and fill.
# NEVER commit real values. Backend secrets live in Secret Manager, not here.

# --- Firebase web config (public; safe to ship to the client) ---
NG_APP_FIREBASE_API_KEY=
NG_APP_FIREBASE_AUTH_DOMAIN=
NG_APP_FIREBASE_PROJECT_ID=
NG_APP_FIREBASE_STORAGE_BUCKET=
NG_APP_FIREBASE_MESSAGING_SENDER_ID=
NG_APP_FIREBASE_APP_ID=
NG_APP_FIREBASE_MEASUREMENT_ID=

# --- Platform ---
NG_APP_ROOT_DOMAIN=soteriaforge.com
NG_APP_APPCHECK_SITE_KEY=

# --- Backend secrets (set via: firebase functions:secrets:set <NAME>) ---
# STRIPE_SECRET_KEY
# STRIPE_WEBHOOK_SECRET
# (LLM provider keys for Phase 6, video provider keys for Phase 2, etc.)
