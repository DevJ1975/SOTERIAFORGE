rules_version = '2';

// Soteria Assurance — Firestore security rules.
// Authoritative tenant isolation + RBAC. Privileged writes (claims, provisioning,
// entitlements, leaderboard recompute) go through Cloud Functions (admin SDK
// bypasses rules), so client write surfaces here are deliberately narrow.
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- helpers ------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }
    function claims() {
      return request.auth.token;
    }
    function role() {
      return isSignedIn() ? claims().role : '';
    }
    function isSuperadmin() {
      return role() == 'superadmin';
    }
    // True if caller belongs to (or is superadmin for) the given tenant.
    function inTenant(tenantId) {
      return isSuperadmin() || (isSignedIn() && claims().tenantId == tenantId);
    }
    function isTenantAdmin(tenantId) {
      return isSuperadmin() || (role() == 'tenant_admin' && claims().tenantId == tenantId);
    }
    function canAuthor(tenantId) {
      return isTenantAdmin(tenantId) || (role() == 'instructor' && claims().tenantId == tenantId);
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ---- platform (superadmin only; config seeded server-side) --------------
    match /platform/{doc=**} {
      allow read: if isSuperadmin();
      allow write: if false; // server-side only
    }

    // ---- tenants ------------------------------------------------------------
    match /tenants/{tenantId} {
      // Members of the tenant (and superadmin) may read the tenant doc/branding.
      allow read: if inTenant(tenantId);
      // Lifecycle (create/suspend/brand) is a privileged op via Cloud Functions.
      allow write: if false;

      // members: a user reads their own member doc + admins read all in-tenant.
      match /members/{uid} {
        allow read: if isSelf(uid) ? inTenant(tenantId) : isTenantAdmin(tenantId);
        // A learner may update ONLY profile fields on their own doc. Everything
        // else is server-only (Cloud Functions / Admin SDK): role/status/tenantId
        // (claim-bearing), the gamification + credit state (xp, level, streakDays,
        // earnedBadgeIds — the Open-Badges compliance record), fcmTokens (set via
        // the registerFcmToken callable), and lastStreakReminderAt. An allowlist
        // (default-deny) is used so any new server-owned field stays protected
        // automatically — a learner must not be able to forge XP, levels,
        // completion badges, streaks, or push tokens.
        allow update: if isSelf(uid) && inTenant(tenantId)
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['displayName', 'avatarUrl', 'updatedAt']);
        allow create, delete: if false;
      }

      // courses + nested content
      match /courses/{courseId} {
        allow read: if inTenant(tenantId);
        allow create, update, delete: if canAuthor(tenantId);

        match /modules/{moduleId} {
          allow read: if inTenant(tenantId);
          allow write: if canAuthor(tenantId);
        }

        // enrollments: a learner reads/writes only their own progress doc, but
        // credit-bearing fields (progressPct/completed/score/cmi.completedModuleIds)
        // are server-only (the `completeModule`/`submitQuiz` admin-SDK writers
        // bypass rules). Self-writes are limited to runtime/bookmark state so a
        // learner cannot forge completion or score (anti-cheat).
        match /enrollments/{uid} {
          allow read: if isSelf(uid) ? inTenant(tenantId) : isTenantAdmin(tenantId);
          // Self may create only a zero-progress enrollment (no forged completion/
          // score). completedModuleIds must also be empty: the server trusts the
          // existing cmi.completedModuleIds as the prior-progress baseline when
          // recomputing progress on completeModule/submitQuiz, so a seeded list at
          // create time would let one real completion inflate to full course credit.
          allow create: if isSelf(uid) && inTenant(tenantId)
            && request.resource.data.tenantId == tenantId
            && request.resource.data.get('progressPct', 0) == 0
            && request.resource.data.get('completed', false) == false
            && !('score' in request.resource.data)
            && request.resource.data.get('cmi', {}).get('completedModuleIds', []) == [];
          // Self may update ONLY runtime/bookmark state; credit-bearing fields are
          // server-only. Use .get(field, default) so optional fields (score, cmi,
          // completedModuleIds) compare safely whether or not they are present.
          allow update: if isSelf(uid) && inTenant(tenantId)
            && request.resource.data.tenantId == resource.data.tenantId
            && request.resource.data.get('progressPct', 0) == resource.data.get('progressPct', 0)
            && request.resource.data.get('completed', false) == resource.data.get('completed', false)
            && request.resource.data.get('score', -1) == resource.data.get('score', -1)
            && request.resource.data.get('cmi', {}).get('completedModuleIds', [])
               == resource.data.get('cmi', {}).get('completedModuleIds', []);
          allow delete: if isTenantAdmin(tenantId);
        }
      }

      match /quizzes/{quizId} {
        allow read: if inTenant(tenantId);
        allow write: if canAuthor(tenantId);
      }
      match /games/{gameId} {
        allow read: if inTenant(tenantId);
        allow write: if canAuthor(tenantId);
      }
      match /badges/{badgeId} {
        allow read: if inTenant(tenantId);
        allow write: if canAuthor(tenantId);
      }

      // leaderboard: readable in-tenant, written only server-side (anti-cheat).
      match /leaderboard/{period} {
        allow read: if inTenant(tenantId);
        allow write: if false;
      }

      // audit log: admins read; append-only, written server-side only.
      match /audit/{entryId} {
        allow read: if isTenantAdmin(tenantId);
        allow write: if false;
      }

      // SCORM package metadata: in-tenant read; written by the unzip function.
      match /scormPackages/{packageId} {
        allow read: if inTenant(tenantId);
        allow write: if false;
      }

      // AI knowledge base + vectors: admin-managed; never client-writable vectors.
      // Paths are flat under the tenant document to keep Firestore segment counts
      // even (odd-segment paths are unreachable via the client SDK).
      match /knowledgeBase/{docId} {
        allow read: if inTenant(tenantId);
        allow write: if isTenantAdmin(tenantId);
      }
      match /vectors/{docId=**} {
        allow read, write: if false; // server-side retrieval only
      }
      // Conversations: a learner reads/writes only their own thread.
      match /conversations/{uid}/messages/{msgId} {
        allow read, create: if isSelf(uid) && inTenant(tenantId);
        allow update, delete: if false;
      }
    }

    // ---- LRS statements: append-only, written server-side -------------------
    // Path is flat (lrs/{stmtId}) so segment count is even and client-reachable
    // for emulator testing; the allow rules still deny all client writes.
    match /lrs/{stmtId} {
      allow read: if isSuperadmin();
      allow write: if false;
    }

    // ---- Global course library (platform) -----------------------------------
    // Any signed-in user may browse the shared library; superadmin authors it.
    // Distribution into tenants happens server-side (shareLibraryCourse).
    match /library/{courseId} {
      allow read: if isSignedIn();
      allow write: if isSuperadmin();
      match /modules/{moduleId} {
        allow read: if isSignedIn();
        allow write: if isSuperadmin();
      }
    }

    // ---- B2C storefront -----------------------------------------------------
    // catalog/{productId} and customers/{uid} are top-level collections so the
    // path segment count stays even (previously b2c/catalog/{x} was 3 segments —
    // unreachable as a Firestore document reference from the client SDK).
    match /catalog/{productId} {
      allow read: if true; // public catalog
      allow write: if isSuperadmin();
    }
    match /customers/{uid} {
      allow read: if isSelf(uid) || isSuperadmin();
      // Entitlements/purchases are written only by verified Stripe webhooks.
      allow write: if false;
    }

    // ---- Stripe idempotency log: server-side only ---------------------------
    // Flat collection (even segment count) so it's a valid document path.
    match /stripeEvents/{eventId} {
      allow read, write: if false;
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
