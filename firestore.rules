rules_version = '2';

// Soteria FORGE Firestore rules.
//
// Deny-by-default: every collection must be explicitly opened up, in the same
// PR that introduces it, together with rules unit tests (see
// libs/data-access/src/rules/firestore.rules.spec.ts).
//
// Tenant isolation is enforced via custom claims (request.auth.token.tenantId,
// request.auth.token.role), which are set exclusively by Cloud Functions; the
// Admin SDK bypasses these rules, so "write: if false" means "Cloud Functions
// only".
service cloud.firestore {
  match /databases/{database}/documents {
    // ---------------------------------------------------------------------
    // Helpers
    // ---------------------------------------------------------------------
    function signedIn() {
      return request.auth != null;
    }

    function role() {
      return request.auth.token.role;
    }

    function isSuperadmin() {
      return signedIn() && role() == 'superadmin';
    }

    function inTenant(tenantId) {
      return signedIn() && request.auth.token.tenantId == tenantId;
    }

    // Tenant-scoped content authors. Superadmin is handled separately.
    function isAuthoring() {
      return signedIn() && role() in ['tenant_admin', 'instructor'];
    }

    match /tenants/{tenantId} {
      // Tenant documents: members may read their own tenant; only superadmin
      // (or Cloud Functions via Admin SDK) may write.
      allow read: if isSuperadmin() || inTenant(tenantId);
      allow write: if isSuperadmin();

      // Members: readable by the tenant roster and superadmin. All writes go
      // through Cloud Functions (invites, role changes, deactivation).
      match /members/{memberUid} {
        allow read: if isSuperadmin() || inTenant(tenantId);
        allow write: if false;

        // XP ledger: a member may read their own events; authoring roles and
        // superadmin may read anyone's. All writes go through the gamification
        // Cloud Functions (Admin SDK bypasses rules).
        match /xpEvents/{eventId} {
          allow read: if isSuperadmin()
            || (inTenant(tenantId) && isAuthoring())
            || (signedIn() && request.auth.uid == memberUid);
          allow write: if false;
        }

        // Badge awards (Open Badges credentials): same visibility as the XP
        // ledger; issued exclusively by Cloud Functions.
        match /awards/{badgeId} {
          allow read: if isSuperadmin()
            || (inTenant(tenantId) && isAuthoring())
            || (signedIn() && request.auth.uid == memberUid);
          allow write: if false;
        }
      }

      // Courses: learners only see published content; authoring roles
      // (tenant_admin, instructor) and superadmin also see drafts/archived.
      // Writers must be authoring roles inside the tenant (or superadmin) and
      // may not spoof another tenant via the embedded tenantId field.
      match /courses/{courseId} {
        allow read: if isSuperadmin()
          || (inTenant(tenantId)
            && (resource.data.status == 'published' || isAuthoring()));
        allow create, update: if (isSuperadmin() || (inTenant(tenantId) && isAuthoring()))
          && request.resource.data.tenantId == tenantId;
        allow delete: if isSuperadmin() || (inTenant(tenantId) && isAuthoring());

        // Modules: gated on tenant membership for reads (no published gating
        // at this level); writes are authoring-only, with the same
        // tenantId-spoofing guard as courses.
        match /modules/{moduleId} {
          allow read: if isSuperadmin() || inTenant(tenantId);
          allow create, update: if (isSuperadmin() || (inTenant(tenantId) && isAuthoring()))
            && request.resource.data.tenantId == tenantId;
          allow delete: if isSuperadmin() || (inTenant(tenantId) && isAuthoring());
        }

        // Enrollments: keyed by the enrollee's uid. The enrollee may read and
        // upsert their own enrollment (progress, scores, cmi state) within
        // their own tenant only; authoring roles and superadmin may read.
        // Deletes are Cloud Functions only.
        match /enrollments/{enrolleeUid} {
          allow read: if isSuperadmin()
            || (inTenant(tenantId) && isAuthoring())
            || (signedIn() && request.auth.uid == enrolleeUid);
          allow create, update: if signedIn()
            && request.auth.uid == enrolleeUid
            && inTenant(tenantId)
            && request.resource.data.uid == enrolleeUid;
          allow delete: if false;
        }
      }

      // Course drafts (Forge Studio authoring docs): same policy as courses —
      // learners only see published drafts; authoring roles and superadmin
      // see everything and may write. Draft docs carry no embedded tenantId
      // field (see @forge/shared courseDraft), so there is no spoofing guard;
      // the path alone scopes them to the tenant.
      match /courseDrafts/{courseId} {
        allow read: if isSuperadmin()
          || (inTenant(tenantId)
            && (resource.data.status == 'published' || isAuthoring()));
        allow create, update: if isSuperadmin() || (inTenant(tenantId) && isAuthoring());
        allow delete: if isSuperadmin() || (inTenant(tenantId) && isAuthoring());
      }

      // Badges: tenant-readable metadata; issued/managed by Cloud Functions.
      match /badges/{badgePath=**} {
        allow read: if isSuperadmin() || inTenant(tenantId);
        allow write: if false;
      }

      // Leaderboard: tenant-readable, denormalized by Cloud Functions.
      match /leaderboard/{periodPath=**} {
        allow read: if isSuperadmin() || inTenant(tenantId);
        allow write: if false;
      }

      // Game results: players create their own result docs (uid field must
      // match the caller) inside their own tenant; scores must be
      // non-negative integers and the game must be a known platform game.
      // Players may read their own results; authoring roles and superadmin
      // may read all. Updates (e.g. the xpAwarded stamp) and deletes are
      // Cloud Functions only.
      match /gameResults/{resultId} {
        allow read: if isSuperadmin()
          || (inTenant(tenantId) && isAuthoring())
          || (signedIn() && resource.data.uid == request.auth.uid);
        allow create: if signedIn()
          && inTenant(tenantId)
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.score is int
          && request.resource.data.score >= 0
          && request.resource.data.game in ['hazard-hunter', 'peril'];
        allow update, delete: if false;
      }

      // PERIL! realtime matches: host-authoritative multiplayer sessions.
      // Any tenant member may read (the lobby lists open matches). Creates
      // must be self-hosted and start 'open'. Updates keep the host immutable
      // (hostUid may never change); finer-grained join validation (e.g.
      // players-array-only diffs) is client-tolerated in v1 — a
      // server-authoritative Cloud Functions referee arrives with Phase 4.1.
      match /matches/{matchId} {
        allow read: if isSuperadmin() || inTenant(tenantId);
        allow create: if signedIn()
          && inTenant(tenantId)
          && request.resource.data.hostUid == request.auth.uid
          && request.resource.data.status == 'open';
        allow update: if signedIn()
          && inTenant(tenantId)
          && request.resource.data.hostUid == resource.data.hostUid;
        allow delete: if isSuperadmin()
          || (inTenant(tenantId) && request.auth.uid == resource.data.hostUid);

        // Match events (buzz/answer/wager/select + host 'state' snapshots):
        // an append-only log. Players may only write events as themselves
        // (uid must match the caller); nothing in the log is ever edited or
        // deleted by clients.
        match /events/{eventId} {
          allow read: if isSuperadmin() || inTenant(tenantId);
          allow create: if signedIn()
            && inTenant(tenantId)
            && request.resource.data.uid == request.auth.uid;
          allow update, delete: if false;
        }
      }

      // xAPI statements (the per-tenant LRS store): readable by superadmin
      // and in-tenant authoring roles only — learners may not read the
      // firehose. All writes go through the recordStatements Cloud Function
      // (Admin SDK bypasses rules).
      match /xapiStatements/{statementId} {
        allow read: if isSuperadmin() || (inTenant(tenantId) && isAuthoring());
        allow write: if false;
      }
    }

    // -----------------------------------------------------------------------
    // B2C storefront. The docblock paths /b2c/catalog/{productId} and
    // /b2c/customers/{uid} are odd-segment (non-document) paths, so the
    // concrete layout interposes the fixed singleton document /b2c/store
    // (see libs/data-access collections.ts):
    //   /b2c/store/catalog/{productId}
    //   /b2c/store/customers/{uid}
    // -----------------------------------------------------------------------

    // Catalog: world-readable (public, SEO-crawled storefront); only
    // superadmin curates products.
    match /b2c/store/catalog/{productId} {
      allow read: if true;
      allow write: if isSuperadmin();
    }

    // Customers: each customer may read only their own doc. Entitlements and
    // purchase history are written exclusively by the Stripe webhook handler
    // (Cloud Functions).
    match /b2c/store/customers/{customerUid} {
      allow read: if signedIn() && request.auth.uid == customerUid;
      allow write: if false;
    }

    // Everything not explicitly matched above is denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
