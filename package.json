{
  "name": "soteria-forge",
  "version": "0.1.0",
  "license": "UNLICENSED",
  "private": true,
  "description": "Soteria FORGE — production-grade, multi-tenant LMS (B2B + B2C). Phase 0 foundation.",
  "scripts": {
    "start:learner": "nx serve learner",
    "start:admin": "nx serve admin",
    "start:superadmin": "nx serve superadmin",
    "start:storefront": "nx serve storefront",
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "affected:build": "nx affected -t build",
    "affected:test": "nx affected -t test",
    "affected:lint": "nx affected -t lint",
    "emulators": "firebase emulators:start",
    "test:rules": "nx test data-access --testPathPattern=rules",
    "functions:build": "nx build functions",
    "functions:deploy": "firebase deploy --only functions",
    "format": "nx format:write",
    "format:check": "nx format:check"
  },
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
