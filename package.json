{
  "name": "soteria-forge",
  "version": "0.1.0",
  "license": "UNLICENSED",
  "private": true,
  "description": "Soteria FORGE — production-grade, multi-tenant LMS (B2B + B2C). Phase 0 foundation.",
  "scripts": {
    "start:learner": "nx serve learner",
    "start:admin": "nx serve admin",
    "start:superadmin": "nx serve superadmin",
    "start:storefront": "nx serve storefront",
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "affected:build": "nx affected -t build",
    "affected:test": "nx affected -t test",
    "affected:lint": "nx affected -t lint",
    "emulators": "firebase emulators:start",
    "seed": "tsx --tsconfig tools/seed/tsconfig.json tools/seed/seed-emulator.ts",
    "test:rules": "firebase emulators:exec --only firestore,storage \"nx test data-access --testPathPattern=rules --skip-nx-cache\"",
    "functions:build": "nx build functions",
    "functions:deploy": "firebase deploy --only functions",
    "format": "nx format:write",
    "format:check": "nx format:check",
    "cap:sync": "cap sync",
    "cap:copy": "cap copy",
    "cap:android": "cap run android",
    "cap:ios": "cap run ios",
    "loadtest:login-storm": "k6 run tools/load-test/scenarios/login-storm.js",
    "loadtest:content-pull": "k6 run tools/load-test/scenarios/content-pull.js",
    "loadtest:sync-storm": "k6 run tools/load-test/scenarios/sync-storm.js",
    "loadtest:soak": "k6 run tools/load-test/scenarios/soak.js",
    "loadtest:reconcile": "tsx --tsconfig tools/load-test/tsconfig.json tools/load-test/reconcile.ts"
  },
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "dependencies": {
    "@angular/animations": "~20.0.0",
    "@angular/cdk": "~20.0.0",
    "@angular/common": "~20.0.0",
    "@angular/compiler": "~20.0.0",
    "@angular/core": "~20.0.0",
    "@angular/fire": "~20.0.0",
    "@angular/forms": "~20.0.0",
    "@angular/platform-browser": "~20.0.0",
    "@angular/platform-browser-dynamic": "~20.0.0",
    "@angular/platform-server": "~20.0.0",
    "@angular/router": "~20.0.0",
    "@angular/service-worker": "~20.0.0",
    "@angular/ssr": "~20.0.0",
    "@capacitor/android": "^7.6.7",
    "@capacitor/core": "^7.6.7",
    "@capacitor/filesystem": "^7.1.8",
    "@capacitor/ios": "^7.6.7",
    "@capacitor/network": "^7.0.4",
    "@capacitor/preferences": "^7.0.4",
    "@ngrx/signals": "~20.0.0",
    "@primeuix/themes": "^1.2.5",
    "firebase": "~11.6.0",
    "firebase-admin": "~13.4.0",
    "firebase-functions": "~6.3.0",
    "phaser": "~3.90.0",
    "primeicons": "~7.0.0",
    "primeng": "~20.4.0",
    "rxjs": "~7.8.0",
    "three": "^0.182.0",
    "tslib": "^2.8.0",
    "zod": "~3.24.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~20.0.0",
    "@angular-devkit/core": "~20.0.0",
    "@angular-devkit/schematics": "~20.0.0",
    "@angular/build": "~20.0.0",
    "@angular/cli": "~20.0.0",
    "@angular/compiler-cli": "~20.0.0",
    "@capacitor/cli": "^7.6.7",
    "@eslint/js": "^9.8.0",
    "@firebase/rules-unit-testing": "~4.0.0",
    "@nx/angular": "21.2.4",
    "@nx/devkit": "21.2.4",
    "@nx/esbuild": "^21.2.4",
    "@nx/eslint": "21.2.4",
    "@nx/eslint-plugin": "21.2.4",
    "@nx/jest": "21.2.4",
    "@nx/js": "21.2.4",
    "@nx/node": "^21.2.4",
    "@nx/playwright": "21.2.4",
    "@nx/web": "21.2.4",
    "@nx/workspace": "21.2.4",
    "@playwright/test": "~1.50.0",
    "@schematics/angular": "~20.0.0",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@types/jest": "~29.5.0",
    "@types/node": "~22.10.0",
    "@types/three": "^0.182.0",
    "@typescript-eslint/eslint-plugin": "~8.34.0",
    "@typescript-eslint/parser": "~8.34.0",
    "@typescript-eslint/utils": "^8.29.0",
    "angular-eslint": "^20.0.0",
    "esbuild": "^0.28.0",
    "eslint": "~9.18.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-playwright": "^1.6.2",
    "firebase-tools": "~14.0.0",
    "jest": "~29.7.0",
    "jest-environment-jsdom": "~29.7.0",
    "jest-environment-node": "^29.7.0",
    "jest-preset-angular": "~14.6.0",
    "nx": "21.2.4",
    "prettier": "~3.4.0",
    "ts-jest": "~29.2.0",
    "ts-node": "~10.9.0",
    "tsx": "~4.19.0",
    "typescript": "~5.8.0",
    "typescript-eslint": "^8.29.0"
  },
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  }
}
