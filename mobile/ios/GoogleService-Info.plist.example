<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Replace with your real GoogleService-Info.plist from the Firebase console
  (Project settings > Your apps > iOS). Rename to GoogleService-Info.plist.
  DO NOT COMMIT the real file — it is gitignored.
-->
<plist version="1.0">
<dict>
	<key>API_KEY</key>
	<string>YOUR_IOS_API_KEY</string>
	<key>BUNDLE_ID</key>
	<string>com.soteria.assurance</string>
	<key>PROJECT_ID</key>
	<string>your-firebase-project-id</string>
	<key>STORAGE_BUCKET</key>
	<string>your-firebase-project-id.appspot.com</string>
	<key>GOOGLE_APP_ID</key>
	<string>1:000000000000:ios:0000000000000000000000</string>
	<key>GCM_SENDER_ID</key>
	<string>000000000000</string>
	<key>IS_GCM_ENABLED</key>
	<true/>
	<key>PLIST_VERSION</key>
	<string>1</string>
</dict>
</plist>
